// pemie.ai — modelo de datos multi-tenant.
// Tenencia: Workspace (equipo) -> Project -> {repos, commits, informes, HUs, board, agentes}.
// Todo dato de negocio se scopea por workspaceId/projectId en la capa de servicios.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth & tenencia ──────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String? // null si solo entra por OAuth
  name         String?
  avatarUrl    String?
  githubLogin  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts    Account[]
  sessions    Session[]
  memberships Membership[]
  notes       Note[]
  objectives  ObjectiveHistory[]
  contributor Contributor[]

  @@map("users")
}

// Proveedores OAuth vinculados (github, etc.)
model Account {
  id                String  @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  invitations Invitation[]
  projects    Project[]
  apiKeys     ApiKey[]
  auditLogs   AuditLog[]

  @@map("workspaces")
}

model Membership {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        String    @default("member") // owner | admin | member | viewer
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@map("memberships")
}

model Invitation {
  id          String    @id @default(cuid())
  workspaceId String
  email       String
  role        String    @default("member")
  token       String    @unique
  status      String    @default("pending") // pending | accepted | revoked
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("invitations")
}

// ─── Proyecto e ingesta ───────────────────────────────────────────────

model Project {
  id           String   @id @default(cuid())
  workspaceId  String
  name         String
  slug         String
  description  String?
  key          String   @default("PRJ") // prefijo para keys de HU: PRJ-123
  domainConfig Json? // DomainConfig (packages/shared). null => DEFAULT_DOMAIN_CONFIG
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  repos        Repo[]
  contributors Contributor[]
  commits      Commit[]
  objective    Objective?
  objectiveLog ObjectiveHistory[]
  reports      Report[]
  notes        Note[]
  epics        Epic[]
  userStories  UserStory[]
  boards       Board[]
  agents       Agent[]
  apiKeys      ApiKey[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@map("projects")
}

model Repo {
  id             String   @id @default(cuid())
  projectId      String
  provider       String   @default("github")
  owner          String
  name           String
  url            String?
  externalId     String?
  installationId String?
  createdAt      DateTime @default(now())
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  commits        Commit[]

  @@unique([projectId, provider, owner, name])
  @@index([projectId])
  @@map("repos")
}

model Contributor {
  id              String      @id @default(cuid())
  projectId       String
  githubLogin     String
  name            String?
  avatarUrl       String?
  userId          String? // vinculado a un User si el contributor es miembro
  createdAt       DateTime    @default(now())
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user            User?       @relation(fields: [userId], references: [id])
  commits         Commit[]
  assignedStories UserStory[]
  assignedCards   Card[]

  @@unique([projectId, githubLogin])
  @@index([projectId])
  @@map("contributors")
}

model Commit {
  id            String      @id @default(cuid())
  projectId     String
  repoId        String
  contributorId String
  sha           String
  message       String
  domain        String      @default("otro")
  committedAt   DateTime
  createdAt     DateTime    @default(now())
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  repo          Repo        @relation(fields: [repoId], references: [id], onDelete: Cascade)
  contributor   Contributor @relation(fields: [contributorId], references: [id], onDelete: Cascade)

  @@unique([repoId, sha])
  @@index([projectId, committedAt])
  @@index([contributorId])
  @@map("commits")
}

// ─── Objetivo, informes y notas (flujo Hermes generalizado) ───────────

model Objective {
  id          String   @id @default(cuid())
  projectId   String   @unique
  description String
  updatedById String?
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("objectives")
}

model ObjectiveHistory {
  id          String   @id @default(cuid())
  projectId   String
  description String
  updatedById String?
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  updatedBy   User?    @relation(fields: [updatedById], references: [id])

  @@index([projectId, createdAt])
  @@map("objective_history")
}

model Report {
  id        String   @id @default(cuid())
  projectId String
  date      String // YYYY-MM-DD (o "todos" para general)
  slot      String   @default("manual")
  scope     String   @default("day") // day | general
  comment   String?
  verdict   String?
  score     Float?
  metrics   Json?
  agentId   String?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agent     Agent?   @relation(fields: [agentId], references: [id])
  notes     Note[]

  @@unique([projectId, date, slot])
  @@index([projectId, createdAt])
  @@map("reports")
}

model Note {
  id          String    @id @default(cuid())
  projectId   String
  authorId    String?
  message     String
  status      String    @default("pending") // pending | processed
  response    String?
  reportId    String?
  createdAt   DateTime  @default(now())
  processedAt DateTime?
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author      User?     @relation(fields: [authorId], references: [id])
  report      Report?   @relation(fields: [reportId], references: [id])

  @@index([projectId, status, createdAt])
  @@map("notes")
}

// ─── Historias de Usuario ─────────────────────────────────────────────

model Epic {
  id          String      @id @default(cuid())
  projectId   String
  title       String
  description String?
  createdAt   DateTime    @default(now())
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stories     UserStory[]

  @@index([projectId])
  @@map("epics")
}

model UserStory {
  id                 String   @id @default(cuid())
  projectId          String
  key                String // PRJ-123
  title              String
  narrative          Json? // UserStoryNarrative { role, want, benefit }
  acceptanceCriteria Json? // AcceptanceCriterion[]
  priority           String   @default("medium") // low | medium | high | critical
  storyPoints        Int?
  status             String   @default("backlog")
  epicId             String?
  assigneeId         String?
  createdById        String?
  createdByAgentId   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  project            Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  epic               Epic?        @relation(fields: [epicId], references: [id])
  assignee           Contributor? @relation(fields: [assigneeId], references: [id])
  card               Card?

  @@unique([projectId, key])
  @@index([projectId, status])
  @@index([assigneeId])
  @@map("user_stories")
}

// ─── Kanban ───────────────────────────────────────────────────────────

model Board {
  id        String   @id @default(cuid())
  projectId String
  name      String   @default("Board")
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns   Column[]
  cards     Card[]

  @@index([projectId])
  @@map("boards")
}

model Column {
  id       String @id @default(cuid())
  boardId  String
  name     String
  order    Int
  wipLimit Int?
  board    Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards    Card[]

  @@index([boardId])
  @@map("columns")
}

model Card {
  id          String         @id @default(cuid())
  boardId     String
  columnId    String
  order       Float
  type        String         @default("task") // story | task | bug
  title       String
  description String?
  userStoryId String?        @unique
  assigneeId  String?
  labels      Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  board       Board          @relation(fields: [boardId], references: [id], onDelete: Cascade)
  column      Column         @relation(fields: [columnId], references: [id], onDelete: Cascade)
  userStory   UserStory?     @relation(fields: [userStoryId], references: [id])
  assignee    Contributor?   @relation(fields: [assigneeId], references: [id])
  activities  CardActivity[]

  @@index([boardId, columnId])
  @@index([assigneeId])
  @@map("cards")
}

model CardActivity {
  id        String   @id @default(cuid())
  cardId    String
  actorType String // user | agent
  actorId   String?
  action    String
  fromValue String?
  toValue   String?
  createdAt DateTime @default(now())
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, createdAt])
  @@map("card_activities")
}

// ─── Agentes, API keys y trazabilidad ─────────────────────────────────

model Agent {
  id        String   @id @default(cuid())
  projectId String
  name      String
  kind      String   @default("mcp")
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  apiKeys   ApiKey[]
  reports   Report[]

  @@index([projectId])
  @@map("agents")
}

model ApiKey {
  id          String    @id @default(cuid())
  workspaceId String
  projectId   String?
  agentId     String?
  name        String
  hashedKey   String    @unique
  prefix      String // primeros chars visibles para identificar la key
  scopes      String[] // ApiScope[]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agent       Agent?    @relation(fields: [agentId], references: [id])

  @@index([workspaceId])
  @@index([projectId])
  @@map("api_keys")
}

model AuditLog {
  id          String    @id @default(cuid())
  workspaceId String
  actorType   String // user | agent
  actorId     String?
  action      String
  entity      String?
  entityId    String?
  meta        Json?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@map("audit_logs")
}
