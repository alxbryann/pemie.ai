# ─── Backend (apps/api) ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# Postgres (docker compose provee uno local en localhost:5433)
DATABASE_URL=postgresql://pemie:pemie@localhost:5433/pemie?schema=public

# Sesiones / JWT
SESSION_SECRET=change-me-in-prod-please-32-chars-min
WEB_ORIGIN=http://localhost:5173

# GitHub OAuth (login)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# GitHub App (conexión de repos + webhooks)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=

# Claude API (generación server-side de HUs / informes)
ANTHROPIC_API_KEY=

# ─── Frontend (apps/web) ───────────────────────────────────────────────
VITE_API_URL=http://localhost:4000
